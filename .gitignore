# .gitignore for LMS Project

# Environment variables (contains sensitive data)
backend/.env

# Node modules
backend/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Database files (if using SQLite)
backend/*.db
backend/*.sqlite
backend/*.sqlite3
